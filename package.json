{
  "description": "A collection of packages for working with the Blackbaud LMS's front-end APIs",
  "homepage": "https://github.com/groton-school/msar#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/groton-school/msar.git"
  },
  "author": {
    "name": "Seth Battis",
    "email": "sbattis@groton.org"
  },
  "type": "module",
  "scripts": {
    "build": "run-s build:*",
    "build:paths": "monorepo-package-paths -w --repository --homepage --author",
    "build:compile": "lerna run build",
    "release": "run-s release:*",
    "release:build": "run-s build",
    "release:git": "git push --follow-tags",
    "release:login": "npm login",
    "release:publish": "pnpm publish -r --access public"
  },
  "devDependencies": {
    "@battis/eslint-config": "^2.1.0",
    "@battis/prettier-config": "^1.7.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/config-pnpm-scopes": "^19.9.1",
    "lerna": "^8.2.4",
    "monorepo-package-paths": "^0.4.4",
    "msar": "workspace:*",
    "npm-run-all": "^4.1.5"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
